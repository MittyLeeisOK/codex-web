#!/usr/bin/env bash
set -euxo pipefail

rm -rf scratch/ChatGPT.app scratch/asar
unzip -o "$HOSTED_CODEX_APP_ZIP" -d scratch/
asar extract "scratch/ChatGPT.app/Contents/Resources/app.asar" "scratch/asar"
cp assets/* scratch/asar/webview/
PWA_SOURCE_ICON="scratch/asar/webview/assets/app-D0g8sCle.png"
PWA_TARGET_ICON="scratch/asar/webview/assets/pwa-icon-512.png"
PWA_ICON_SIZE=512
PWA_TOTAL_PADDING_PERCENT=25
PWA_CONTENT_SIZE=$((PWA_ICON_SIZE * (100 - PWA_TOTAL_PADDING_PERCENT) / 100))
PWA_PADDING_TOTAL=$((PWA_ICON_SIZE - PWA_CONTENT_SIZE))
PWA_PADDING_BEFORE=$((PWA_PADDING_TOTAL / 2))
PWA_PADDING_AFTER=$((PWA_PADDING_TOTAL - PWA_PADDING_BEFORE))
sharp -i "$PWA_SOURCE_ICON" -o "$PWA_TARGET_ICON" -f png resize "$PWA_CONTENT_SIZE" "$PWA_CONTENT_SIZE" --fit inside -- flatten white -- extend "$PWA_PADDING_BEFORE" "$PWA_PADDING_AFTER" "$PWA_PADDING_BEFORE" "$PWA_PADDING_AFTER" --background white -- removeAlpha
if [[ -n "${DEV:-}" ]]; then
  prettier --ignore-path /dev/null --ignore-unknown --write "scratch/asar"
else
  patched_files=()
  while IFS= read -r patched_file; do
    if [[ -e "$patched_file" ]]; then
      patched_files+=("$patched_file")
    fi
  done < <(
    awk '/^\+\+\+ b\//{sub(/^\+\+\+ b\//, "scratch/asar/"); print}' patches/*.patch | sort -u
  )
  if (( ${#patched_files[@]} )); then
    prettier --ignore-path /dev/null --ignore-unknown --write "${patched_files[@]}"
  fi
fi
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-remove-csp.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-style.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-preload.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-favicon.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-pwa.patch
# Upstream 26.715.31925 moved the hosted window title atom again; the new
# owner chunk was not uniquely identified this pass. Keep disabled until
# re-mapped (see logs/codex-core-update-2026-07-18-assessment.md).
# patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-thread-title.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-initial-route.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-electron-shim-close-sidebar.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-prosemirror-inputmode.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-use-atfs-for-local-files.patch
# Upstream 26.715.31925 renumbered the React-compiler cache slots (.c(107)
# -> .c(109)) across both composer call sites; the query-param prefill wiring
# was not re-verified safe to auto-remap this pass. Keep disabled until
# re-mapped (see logs/codex-core-update-2026-07-18-assessment.md).
# patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-prompt-search-param.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/webview-app-host-services.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/sentry-disable-shell.patch
patch --batch --forward --strip 1 --fuzz 3 --directory scratch/asar < patches/sentry-disable-webview.patch
rm -rf scratch/asar/node_modules/better-sqlite3
